      let username = this.getUsername(row.username, row.user_id);
		if (username.length > 40) username = username.substr(0, 40);
		username = username.replace(/[^\p{L}\p{N}\-_\s]/ug, "").replace(/[<>"'&]/g, "");
      if (hasGap) {
        html += `
